# Gold Investment Dashboard — 环境变量模板
# 复制此文件为 .env 并填入你的 API Keys

# DeepSeek API (必需 — AI 研判核心模型)
DEEPSEEK_API_KEY=sk-xxx

# OpenAI API (可选 — 双模型辩论的第二模型，缺失时仅用 DeepSeek)
OPENAI_API_KEY=sk-xxx

# FRED API (可选 — 10年期 TIPS 收益率数据，免费注册: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=xxx
